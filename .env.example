# Redis Configuration
# Set this to your Redis Streams host (e.g. redis://192.168.1.8:2727)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_STREAM_PATTERN=tick_stream:*
# Comma-separated segments to skip (segment is the 2nd token in key: tick_stream:{segment}:...)
# Example: spot,equity
REDIS_EXCLUDE_SEGMENTS=spot
REDIS_CONSUMER_GROUP=tick_ingestor
REDIS_CONSUMER_NAME=worker-1
REDIS_BLOCK_MS=5000

# ClickHouse Configuration (local)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=tickstream
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Batching & Performance
CH_INSERT_BATCH_SIZE=5000
CH_FLUSH_INTERVAL_MS=1000

# Startup / correctness behavior
# Backfill behavior:
# - today: only ingest ticks with Redis IDs >= today's market open (IST)
# - all: ingest all available history in streams (from the beginning when no checkpoints exist)
BACKFILL_MODE=today

# Backward compat (optional): if BACKFILL_MODE is not set, this flag controls default.
BACKFILL_FROM_MARKET_OPEN=1
MARKET_OPEN_HHMM=09:15

# Optional cross-stream dedup (equity/spot publishing same payload)
# 0 = disabled; otherwise, dedup near-identical ticks within this TTL window.
DEDUP_TTL_SECONDS=0

# Logging
LOG_LEVEL=INFO
